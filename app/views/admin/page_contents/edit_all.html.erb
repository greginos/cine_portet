<%# ── Font Awesome ── %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
  .icon-picker-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 8px;
    padding: 10px;
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    max-height: 220px;
    overflow-y: auto;
  }
  .icon-option {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid transparent;
    border-radius: 6px;
    cursor: pointer;
    font-size: 1.3rem;
    color: #374151;
    transition: all 0.15s;
    background: #f9fafb;
  }
  .icon-option:hover {
    border-color: #3b82f6;
    background: #eff6ff;
    color: #3b82f6;
  }
  .icon-option.selected {
    border-color: #3b82f6;
    background: #dbeafe;
    color: #1d4ed8;
  }
  .icon-preview {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f3f4f6;
    border-radius: 8px;
    font-size: 1.6rem;
    color: #374151;
    border: 2px solid #e5e7eb;
    flex-shrink: 0;
  }
  .icon-search {
    width: 100%;
    padding: 0.4rem 0.6rem;
    border: 1px solid #d1d5db;
    border-radius: 4px;
    font-size: 0.9rem;
    margin-bottom: 6px;
  }
</style>

<div class="index_content">
  <% if notice %>
    <div class="flash flash_notice"><%= notice %></div>
  <% end %>

  <%= form_tag update_all_admin_page_contents_path, method: :post do %>

    <%
      sections = {
        "hero"     => "🎬 Hero",
        "about"    => "ℹ️ À propos",
        "services" => "🎥 Services",
        "contact"  => "📍 Contact",
        "footer"   => "🔻 Footer",
      }
      short_keys = %w[title subtitle button_text email address icon url copyright]
      grouped = @page_contents.group_by { |pc| pc.key.split("_").first }

      # Bibliothèque d'icônes proposées (classe FA → label)
      icon_library = [
        ["fa-solid fa-film",            "Film"],
        ["fa-solid fa-clapperboard",    "Clap"],
        ["fa-solid fa-video",           "Vidéo"],
        ["fa-solid fa-camera",          "Caméra"],
        ["fa-solid fa-star",            "Étoile"],
        ["fa-solid fa-heart",           "Cœur"],
        ["fa-solid fa-users",           "Groupe"],
        ["fa-solid fa-user",            "Personne"],
        ["fa-solid fa-child",           "Enfant"],
        ["fa-solid fa-clock",           "Horloge"],
        ["fa-solid fa-calendar",        "Calendrier"],
        ["fa-solid fa-ticket",          "Ticket"],
        ["fa-solid fa-couch",           "Canapé"],
        ["fa-solid fa-popcorn",         "Popcorn"],
        ["fa-solid fa-music",           "Musique"],
        ["fa-solid fa-masks-theater",   "Théâtre"],
        ["fa-solid fa-trophy",          "Trophée"],
        ["fa-solid fa-gift",            "Cadeau"],
        ["fa-solid fa-tag",             "Étiquette"],
        ["fa-solid fa-euro-sign",       "Euro"],
        ["fa-solid fa-percent",         "Pourcent"],
        ["fa-solid fa-check-circle",    "Valider"],
        ["fa-solid fa-circle-info",     "Info"],
        ["fa-solid fa-lightbulb",       "Idée"],
        ["fa-solid fa-comments",        "Discussion"],
        ["fa-solid fa-handshake",       "Partenariat"],
        ["fa-solid fa-globe",           "Globe"],
        ["fa-solid fa-map-marker-alt",  "Lieu"],
        ["fa-solid fa-phone",           "Téléphone"],
        ["fa-solid fa-envelope",        "Email"],
        ["fa-solid fa-wifi",            "Wifi"],
        ["fa-solid fa-wheelchair",      "Accessibilité"],
        ["fa-solid fa-leaf",            "Nature"],
        ["fa-solid fa-sun",             "Soleil"],
      ]
    %>

    <% sections.each do |section_key, section_label| %>
      <% items = grouped[section_key] || [] %>
      <% next if items.empty? %>

      <div style="margin-bottom:2.5rem; background:#f9fafb; border:1px solid #e5e7eb; border-radius:8px; padding:1.5rem;">
        <h3 style="font-size:1.1rem; font-weight:bold; margin-bottom:1.2rem; padding-bottom:0.5rem; border-bottom:2px solid #e2e8f0;">
          <%= section_label %>
        </h3>

        <% items.each do |pc| %>
          <% is_icon = pc.key.include?("icon") %>
          <% is_url  = pc.key.include?("url") %>
          <% is_short = short_keys.any? { |k| pc.key.include?(k) } %>

          <div style="margin-bottom:1.6rem;">
            <label style="display:block; font-weight:600; margin-bottom:0.4rem; color:#374151;">
              <%= pc.label %>
              <span style="font-weight:normal; font-size:0.8rem; color:#9ca3af; margin-left:0.3rem;"><%= pc.key %></span>
            </label>

            <% if is_icon %>
              <%# ── Champ icône avec picker visuel ── %>
              <% field_id = "icon_field_#{pc.key}" %>
              <% picker_id = "picker_#{pc.key}" %>
              <% search_id = "search_#{pc.key}" %>

              <div style="display:flex; align-items:center; gap:12px; margin-bottom:6px;">
                <%# Aperçu live %>
                <div class="icon-preview" id="preview_<%= pc.key %>">
                  <i class="<%= pc.value %>"></i>
                </div>
                <%# Champ texte (valeur réelle soumise) %>
                <%= text_field_tag "page_contents[#{pc.key}]", pc.value,
                      id: field_id,
                      placeholder: "fa-solid fa-film",
                      style: "flex:1; padding:0.5rem; border:1px solid #d1d5db; border-radius:4px; font-size:0.9rem; font-family:monospace;",
                      oninput: "updateIconPreview('#{pc.key}', this.value)" %>
                <%# Bouton toggle picker %>
                <a href="#"
                   onclick="event.preventDefault(); togglePicker('<%= picker_id %>')"
                   style="padding:0.5rem 0.9rem; background:#f3f4f6; border:1px solid #d1d5db; border-radius:4px; cursor:pointer; font-size:0.85rem; white-space:nowrap; text-decoration:none; color:#374151;">
                  🎨 Choisir
                </a>
              </div>

              <%# Picker masqué par défaut %>
              <div id="<%= picker_id %>" style="display:none;">
                <input type="text"
                       id="<%= search_id %>"
                       class="icon-search"
                       placeholder="🔍 Rechercher une icône..."
                       oninput="filterIcons('<%= pc.key %>', this.value)">
                <div class="icon-picker-grid" id="grid_<%= pc.key %>">
                  <% icon_library.each do |fa_class, label| %>
                    <div class="icon-option <%= 'selected' if pc.value == fa_class %>"
                         data-class="<%= fa_class %>"
                         data-label="<%= label.downcase %>"
                         title="<%= fa_class %>"
                         onclick="selectIcon('<%= pc.key %>', '<%= fa_class %>', this)">
                      <i class="<%= fa_class %>"></i>
                    </div>
                  <% end %>
                </div>
              </div>

            <% elsif is_url %>
              <%= text_field_tag "page_contents[#{pc.key}]", pc.value,
                    placeholder: "https://...",
                    style: "width:100%; padding:0.5rem; border:1px solid #d1d5db; border-radius:4px; font-size:0.85rem; font-family:monospace;" %>

            <% elsif is_short %>
              <%= text_field_tag "page_contents[#{pc.key}]", pc.value,
                    style: "width:100%; padding:0.5rem; border:1px solid #d1d5db; border-radius:4px; font-size:0.95rem;" %>

            <% else %>
              <%= text_area_tag "page_contents[#{pc.key}]", pc.value,
                    rows: 3,
                    style: "width:100%; padding:0.5rem; border:1px solid #d1d5db; border-radius:4px; font-size:0.95rem; resize:vertical;" %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <div style="margin-top:1.5rem; display:flex; align-items:center; gap:1rem;">
      <%= submit_tag "💾 Enregistrer tous les changements",
            style: "background:#3b82f6; color:white; padding:0.65rem 1.8rem; border:none; border-radius:6px; font-size:1rem; cursor:pointer; font-weight:600;" %>
      <%= link_to "Annuler", admin_page_contents_path, style: "color:#6b7280;" %>
    </div>

  <% end %>
</div>

<script>
  // Affiche / masque le picker
  window.togglePicker = function(pickerId) {
    const picker = document.getElementById(pickerId);
    if (picker) picker.style.display = picker.style.display === 'none' ? 'block' : 'none';
  }

  // Met à jour l'aperçu quand on tape manuellement
  window.updateIconPreview = function(key, value) {
    const preview = document.getElementById('preview_' + key);
    if (preview) preview.innerHTML = '<i class="' + value + '"></i>';
    // Désélectionne toutes les options du picker
    const grid = document.getElementById('grid_' + key);
    if (grid) {
      grid.querySelectorAll('.icon-option').forEach(el => {
        el.classList.toggle('selected', el.dataset.class === value);
      });
    }
  }

  // Sélectionne une icône depuis le picker
  window.selectIcon = function(key, faClass, el) {
    // Met à jour le champ texte
    const field = document.getElementById('icon_field_' + key);
    if (field) field.value = faClass;
    // Met à jour l'aperçu
    updateIconPreview(key, faClass);
    // Ferme le picker
    const picker = el.closest('[id^="picker_"]');
    if (picker) picker.style.display = 'none';
  }

  // Filtre les icônes dans le picker
  window.filterIcons = function(key, query) {
    const grid = document.getElementById('grid_' + key);
    if (!grid) return;
    const q = query.toLowerCase();
    grid.querySelectorAll('.icon-option').forEach(el => {
      const match = el.dataset.label.includes(q) || el.dataset.class.includes(q);
      el.style.display = match ? 'flex' : 'none';
    });
  }
</script>

<%
  # Charge tous les contenus en une seule requête
  @page_contents ||= PageContent.all.index_by(&:key)
  def pc(key); raw(@page_contents[key]&.value.to_s); end
%>

<%# Font Awesome — à déplacer dans application.html.erb si pas déjà présent %>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<div class="min-h-screen bg-gray-50">

  <!-- ═══ HERO ═══ -->
  <section id="accueil" class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <%= image_tag "cinema-background.jpg", class: "w-full h-full object-cover object-center", alt: "Cinéma", style: "opacity:0.5;" %>
      <div class="absolute inset-0 bg-gradient-to-r from-blue-600 via-purple-600 to-pink-500 mix-blend-multiply opacity-80"></div>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
      <h1 class="text-4xl md:text-6xl font-bold mb-6"><%= pc("hero_title") %></h1>
      <p class="text-xl md:text-2xl mb-8"><%= pc("hero_subtitle") %></p>
      <%= link_to pc("hero_button_text"), programmations_path,
            class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
    </div>
  </section>

  <!-- ═══ SESSIONS ═══ -->
  <% @session = Session.current_or_upcoming %>
  <section>
    <% if @session %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">
            Programmation du <%= I18n.l(@session.start_date, format: :short) %>
            au <%= I18n.l(@session.end_date, format: :short) %>
          </h2>
        </div>
        <% @events.each do |event| %>
          <div class="mb-8">
            <%= render partial: "events/event_card_full", locals: { event: event } %>
          </div>
        <% end %>
        <% if @events.any? %>
          <div class="mt-12 mb-6">
            <h3 class="text-2xl font-bold text-gray-800 border-b-2 border-indigo-500 pb-2">Projections</h3>
          </div>
        <% end %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% @programmations.each do |programmation| %>
            <%= render partial: "programmations/programmation_card", locals: { programmation: programmation } %>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center py-12">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Aucune programmation disponible</h2>
        <p class="text-gray-600">Revenez bientôt pour découvrir notre prochaine saison !</p>
      </div>
    <% end %>
  </section>

  <!-- ═══ À PROPOS ═══ -->
  <section id="a-propos" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4"><%= pc("about_title") %></h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto"><%= pc("about_description") %></p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <% [1, 2, 3].each do |n| %>
          <div class="text-center">
            <div class="bg-blue-100 w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4">
              <i class="<%= pc("about_card#{n}_icon") %> text-blue-600 text-xl"></i>
            </div>
            <h3 class="text-xl font-semibold mb-2"><%= pc("about_card#{n}_title") %></h3>
            <p class="text-gray-600"><%= pc("about_card#{n}_text") %></p>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ═══ -->
  <section id="services" class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4"><%= pc("services_title") %></h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto"><%= pc("services_subtitle") %></p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        <% [1, 2].each do |n| %>
          <div class="bg-white p-6 rounded-lg shadow-md">
            <div class="text-blue-600 mb-4">
              <i class="<%= pc("service#{n}_icon") %> text-4xl"></i>
            </div>
            <h3 class="text-xl font-semibold mb-2"><%= pc("service#{n}_title") %></h3>
            <p class="text-gray-600"><%= pc("service#{n}_text") %></p>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- ═══ CONTACT ═══ -->
  <section id="contact" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4"><%= pc("contact_title") %></h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto"><%= pc("contact_subtitle") %></p>
      </div>
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h3 class="text-2xl font-semibold mb-6">Informations</h3>
          <div class="space-y-4">
            <div class="flex items-center">
              <i class="fa-solid fa-location-dot text-blue-600 mr-3 text-xl"></i>
              <span class="text-gray-700"><%= pc("contact_address") %></span>
            </div>
            <div class="flex items-center">
              <i class="fa-solid fa-envelope text-blue-600 mr-3 text-xl"></i>
              <span class="text-gray-700"><%= pc("contact_email") %></span>
            </div>
            <div class="flex items-center">
              <a href="<%= pc("contact_gmaps_url") %>" target="_blank" rel="noopener" aria-label="Google Maps" class="mr-3">
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none">
                  <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" fill="#4285F4"/>
                  <circle cx="12" cy="9" r="2.5" fill="white"/>
                </svg>
              </a>
              <span class="text-gray-700">Itinéraire Google Maps</span>
            </div>
            <div class="flex items-center">
              <a href="<%= pc("contact_waze_url") %>" target="_blank" rel="noopener" aria-label="Waze" class="mr-3">
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" fill="#33CCFF"/>
                  <ellipse cx="12" cy="14" rx="7" ry="5" fill="#33CCFF"/>
                  <circle cx="9.5" cy="15" r="1" fill="#222"/>
                  <circle cx="14.5" cy="15" r="1" fill="#222"/>
                  <path d="M8 17c1.5 1 6.5 1 8-1" stroke="#222" stroke-width="1" stroke-linecap="round"/>
                </svg>
              </a>
              <span class="text-gray-700">Itinéraire Waze</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <footer class="bg-gray-800 text-white py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p><%= pc("footer_copyright") %></p>
    </div>
  </footer>

</div>
